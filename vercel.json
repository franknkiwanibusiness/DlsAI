{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/15 * * * *"
    }
  ],
  "routes": [
    { "src": "/sw.js",           "dest": "/public/sw.js" },
    { "src": "/manifest.json",   "dest": "/public/manifest.json" },
    { "src": "/admin",           "dest": "/index.html" },
    { "src": "/",                "dest": "/index.html" }
  ],
  "env": {
    "VAPID_PUBLIC_KEY": "BMTBoZaETNkmPu3gl42TbHyU9CH6tRTS9_TBGB2-oor3nSvt5WhJyk1PcmOiOLIt5z5xRterBfR2xlY2Ubyq1Do"
  },
  "functions": {
    "api/create-order.js":          { "memory": 256, "maxDuration": 10 },
    "api/cron.js":                  { "memory": 512, "maxDuration": 30 },
    "api/push-subscribe.js":        { "memory": 256, "maxDuration": 10 },
    "api/push-send.js":             { "memory": 256, "maxDuration": 20 },
    "api/push-abandoned-cart.js":   { "memory": 256, "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}