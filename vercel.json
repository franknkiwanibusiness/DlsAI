{
  "version": 2,

  "cleanUrls": true,
  "trailingSlash": false,

  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/15 * * * *"
    }
  ],

  "env": {
    "VAPID_PUBLIC_KEY": "BMTBoZaETNkmPu3gl42TbHyU9CH6tRTS9_TBGB2-oor3nSvt5WhJyk1PcmOiOLIt5z5xRterBfR2xlY2Ubyq1Do"
  },

  "functions": {
    "api/chat.js": {
      "memory": 512,
      "maxDuration": 30
    },

    "api/create-order.js": {
      "memory": 256,
      "maxDuration": 10
    },

    "api/cron.js": {
      "memory": 512,
      "maxDuration": 30
    },

    "api/push-abandoned-cart.js": {
      "memory": 256,
      "maxDuration": 15
    },

    "api/push-send.js": {
      "memory": 256,
      "maxDuration": 20
    },

    "api/push-subscribe.js": {
      "memory": 256,
      "maxDuration": 10
    },

    "api/save-subscription.js": {
      "memory": 256,
      "maxDuration": 10
    },

    "api/send-email.js": {
      "memory": 256,
      "maxDuration": 15
    },

    "api/submit-order.js": {
      "memory": 256,
      "maxDuration": 10
    },

    "api/support.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },

  "headers": [
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|gif|svg|webp|ico|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },

    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}