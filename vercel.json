{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "api/chat.js":                  { "memory": 512, "maxDuration": 30 },
    "api/create-order.js":          { "memory": 256, "maxDuration": 10 },
    "api/cron.js":                  { "memory": 512, "maxDuration": 30 },
    "api/push-abandoned-cart.js":   { "memory": 256, "maxDuration": 15 },
    "api/push-send.js":             { "memory": 256, "maxDuration": 20 },
    "api/push-subscribe.js":        { "memory": 256, "maxDuration": 10 },
    "api/save-subscription.js":     { "memory": 256, "maxDuration": 10 },
    "api/send-email.js":            { "memory": 256, "maxDuration": 15 },
    "api/submit-order.js":          { "memory": 256, "maxDuration": 10 },
    "api/support.js":               { "memory": 256, "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}